        "jsdom": "^29.0.1",
        "puppeteer": "^24.40.0"
    },
    "peerDependencies": {
        "@types/webpack": "^5.28.0",
        "webpack": "^5.28.0"
    },
    "devDependencies": {
        "@eslint/compat": "^2.0.3",
        "@eslint/js": "^10.0.1",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@types/node": "^24.12.0",
        "@types/webpack": "^5.28.5",
        "eslint": "^10.1.0",
        "eslint-plugin-n": "^17.24.0",
        "eslint-plugin-vue": "^10.8.0",
        "globals": "^17.4.0",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.57.2",
        "vitest": "^4.1.1",
        "vue-eslint-parser": "^10.4.0",
        "webpack": "^5.105.4"
    }
}
